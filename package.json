    "memfs": "^4.56.10",
    "npm-in-browser": "^0.1.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^3.0.6",
    "react-router-dom": "^7.9.5",
